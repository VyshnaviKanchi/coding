class Solution(object):
    def searchInsert(self, nums, target):
        left = 0
        right = len(nums) - 1
        while left <= right:
            n = (right+left)//2
            if nums[n] > target:
                right = n-1
            elif nums[n] < target:
                left = n+1
            elif nums[n] == target:
                return n
        return left
        """
        :type nums: List[int]
        :type target: int
        :rtype: int
        """
        
